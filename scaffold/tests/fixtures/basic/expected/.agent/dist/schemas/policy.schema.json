{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://agentflow.dev/schemas/policy.schema.json",
  "title": "AgentFlow Policy",
  "type": "object",
  "required": [
    "filesystem",
    "shell"
  ],
  "properties": {
    "filesystem": {
      "type": "object",
      "required": [
        "read",
        "write",
        "deny"
      ],
      "properties": {
        "read": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "write": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deny": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "shell": {
      "type": "object",
      "required": [
        "allow",
        "deny"
      ],
      "properties": {
        "allow": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deny": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
