{
  "name": "@aglegg/agentflow",
  "version": "0.1.0",
  "description": "CLI and compiler for AgentFlow .afx agent instruction projects.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "Andre Glegg <andreglegg@me.com>",
  "homepage": "https://github.com/andreglegg/agentflow#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andreglegg/agentflow.git"
  },
  "bugs": {
    "url": "https://github.com/andreglegg/agentflow/issues"
  },
  "keywords": [
    "agent",
    "agents",
    "ai",
    "llm",
    "cli",
    "compiler",
    "afx",
    "agents-md",
    "claude",
    "codegen",
    "instructions"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "agentflow": "dist/cli/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "commander": "13.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@types/node": "22.10.5",
    "@typescript-eslint/eslint-plugin": "8.19.1",
    "@typescript-eslint/parser": "8.19.1",
    "eslint": "9.17.0",
    "prettier": "3.4.2",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
